{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "{index.html,app.js,style.css}", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js", "headers": { "cache-control": "no-store" } },
    { "src": "/", "dest": "/index.html", "headers": { "cache-control": "no-store" } },
    { "src": "/(.*)", "dest": "/$1", "headers": { "cache-control": "no-store" } }
  ]
}
